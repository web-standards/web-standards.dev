		"@11ty/eleventy-plugin-rss": "^3.0.0",
		"@eslint/js": "^10.0.1",
		"@netlify/blobs": "^10.7.4",
		"@netlify/cache-utils": "^6.0.5",
		"editorconfig-checker": "^6.1.1",
		"esbuild": "^0.27.4",
		"eslint": "^10.1.0",
		"globals": "^17.4.0",
		"js-yaml": "^4.1.1",
		"lightningcss": "^1.32.0",
		"pagefind": "^1.4.0",
		"puppeteer": "^24.40.0",
		"stylelint": "^17.6.0",
		"stylelint-config-pepelsbey": "^1.2.0",
		"stylelint-order": "^8.1.1"
	},
	"dependencies": {
		"@evilmartians/harmony": "^1.4.0"
