{
	"private": true,
	"type": "module",
	"scripts": {
		"prepare": "git config --local include.path ../.gitconfig",
		"start": "eleventy --serve --quiet",
		"build": "rm -rf dist && eleventy",
		"new": "node scripts/new.js",
		"move": "node scripts/move.js",
		"cover": "node scripts/cover.js",
		"editorconfig": "editorconfig-checker",
		"stylelint": "stylelint \"src/**/*.css\"",
		"eslint": "eslint",
		"test": "npm run editorconfig && npm run stylelint && npm run eslint",
		"social": "node scripts/social.js",
		"stats": "node scripts/stats.js"
	},
	"engines": {
		"node": ">=24"
	},
	"browserslist": [
		"baseline widely available, safari 15"
	],
	"devDependencies": {
		"@11ty/eleventy": "^3.1.5",
		"@11ty/eleventy-img": "^6.0.4",
		"@11ty/eleventy-plugin-rss": "^3.0.0",
		"@eslint/js": "^10.0.1",
		"@netlify/cache-utils": "^6.0.5",
		"browserslist-to-esbuild": "^2.1.1",
		"editorconfig-checker": "^6.1.1",
		"esbuild": "^0.28.0",
		"esbuild-minify-templates": "^0.13.1",
		"eslint": "^10.3.0",
		"globals": "^17.6.0",
		"html-minifier-next": "^6.2.4",
		"js-yaml": "^4.1.1",
		"lightningcss": "^1.32.0",
		"lint-staged.sh": "^0.6.0",
		"pagefind": "^1.5.2",
		"puppeteer": "^24.43.1",
		"stylelint": "^17.11.0",
		"stylelint-config-pepelsbey": "^1.3.0",
		"stylelint-order": "^8.1.1"
	},
	"dependencies": {
		"@evilmartians/harmony": "^1.4.0"
	},
	"stylelint": {
		"extends": [
			"stylelint-config-pepelsbey"
		]
	}
}
