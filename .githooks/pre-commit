#!/bin/sh

set -e

# ------------------------------------------------------------------------------
# 1. Lint staged files
# ------------------------------------------------------------------------------

npx lint-staged.sh "npx editorconfig-checker" "*"
npx lint-staged.sh "npx stylelint" "*.css"
npx lint-staged.sh "npx eslint" "*.js" "*.mjs" "*.cjs"

# ------------------------------------------------------------------------------
# 2. Convert staged cover.png files to AVIF
# ------------------------------------------------------------------------------

cover_files=$(git diff --cached --name-only --diff-filter=ACM | grep '/cover\.png$' || true)

if [ -z "$cover_files" ]; then
	exit 0
fi

if ! command -v avifenc > /dev/null 2>&1; then
	echo "Error: avifenc is not installed. Please install libavif to convert cover.png to AVIF."
	exit 1
fi

for file in $cover_files; do
	dir=$(dirname "$file")
	avif_file="$dir/cover.avif"

	echo "Converting $file to AVIF..."

	if ! avifenc -q 50 --speed 0 "$file" "$avif_file"; then
		echo "Error: avifenc failed to convert $file"
		exit 1
	fi

	# Remove cover.png and stage cover.avif instead
	git rm --cached "$file"
	rm "$file"
	git add "$avif_file"

	echo "Replaced $file with $avif_file"
done
