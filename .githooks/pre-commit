#!/usr/bin/env bash

set -e

# ------------------------------------------------------------------------------
# 1. Convert staged cover.png files to AVIF
# ------------------------------------------------------------------------------

cover_files=()
while IFS= read -r -d '' file; do
	cover_files+=("$file")
done < <(git diff --cached -z --name-only --diff-filter=ACM -- '*/cover.png')

if [ ${#cover_files[@]} -gt 0 ]; then
	# Convert all staged covers in a single Node invocation.
	npm run --silent cover -- "${cover_files[@]}"

	# Restage: remove cover.png, add cover.avif.
	for file in "${cover_files[@]}"; do
		git rm -f "$file"
		git add "$(dirname "$file")/cover.avif"
	done
fi

# ------------------------------------------------------------------------------
# 2. Lint staged files
# ------------------------------------------------------------------------------

npx lint-staged.sh "npx editorconfig-checker" "*"
npx lint-staged.sh "npx stylelint" "*.css"
npx lint-staged.sh "npx eslint" "*.js"

# ------------------------------------------------------------------------------
# 3. Validate staged news/index.yml files
# ------------------------------------------------------------------------------

yml_files=()
while IFS= read -r -d '' file; do
	yml_files+=("$file")
done < <(git diff --cached -z --name-only --diff-filter=ACM -- 'src/news/**/index.yml' ':(exclude)src/news/template/index.yml')

if [ ${#yml_files[@]} -gt 0 ]; then
	node scripts/validate.js "${yml_files[@]}"
fi
